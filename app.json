{
  "expo": {
    "name": "Play by Ear",
    "slug": "play-by-ear",
    "version": "2026.06.2",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "playbyear",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.playbyear"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#192229",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.playbyear"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0517957f-465b-4cff-9fa8-0f9c10016db5"
      }
    },
    "owner": "raghavmallampalli"
  }
}
